PORT=5174
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Telegram Bot API credentials.
# Create a bot via @BotFather, then put your chat/user/channel id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_USERNAME=toru_srang
TELEGRAM_ADMIN_STORE=.data/telegram-admin.json

# true lets the API accept forms locally without sending to Telegram.
TELEGRAM_DRY_RUN=true
